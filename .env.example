# SafariVerse — environment variables
# Copy to .env.local in web/ for local development.
# Set in Railway service variables for production.

# ─────── Database (Railway Postgres) ────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/safariverse

# ─────── AI (Anthropic) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────── Embeddings ─────────────────────────────────────────────
# Pick one provider for the vector embeddings
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ─────── Auth (Clerk) — wired in Week 2 ─────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─────── Image / file storage (Cloudflare R2) ───────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=safariverse
R2_PUBLIC_URL=

# ─────── External content APIs ──────────────────────────────────
YOUTUBE_API_KEY=
GOOGLE_PLACES_API_KEY=
# Instagram Graph access tokens are per-creator; managed via DB

# ─────── GoHighLevel (SafariBoost CRM) ──────────────────────────
GHL_API_KEY=
GHL_SUBACCOUNT_ID=
GHL_PIPELINE_ID_DREAM_STAGE=

# ─────── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
